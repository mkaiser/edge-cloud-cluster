{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "argocd": {
    "fileMatch": [
      "deployment/apps/.+\\.yaml$",
      "deployment/.+/.+\\.yaml$"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Pulumi helm.v3.Release versions in TypeScript source",
      "fileMatch": ["src/.+\\.ts$"],
      "matchStrings": [
        "chart: \"(?<depName>[^\"]+)\",(?:[^\\n]*\\n){1,3}[^\\n]*version: \"(?<currentValue>[^\"]+)\",[^\\n]*\\n(?:[^\\n]*\\n){0,2}[^\\n]*repositoryOpts: \\{ repo: \"(?<registryUrl>[^\"]+)\""
      ],
      "datasourceTemplate": "helm"
    },
    {
      "customType": "regex",
      "description": "Tool versions in scripts/install.sh",
      "fileMatch": ["scripts/install\\.sh"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[^\\s]+) depName=(?<depName>[^\\s]+)\\n[A-Z_]+=\"(?<currentValue>[^\"]+)\""
      ]
    }
  ]
}
